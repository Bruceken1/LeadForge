# ── Vultr ────────────────────────────────────────────────────────────
VULTR_SERVERLESS_INFERENCE_API_KEY=your_vultr_key
VULTR_MODEL=mistralai/Mistral-7B-Instruct-v0.2
# For higher quality:
# VULTR_MODEL=mistralai/Mixtral-8x7B-Instruct-v0.1

# ── Database (PostgreSQL + pgvector on Vultr VM) ──────────────────────
DATABASE_URL=postgresql://leadforge:leadforge@localhost:5432/leadforge

# ── LeadEngine Cloudflare Worker ─────────────────────────────────────
LEADENGINE_API_URL=https://lead-engine-backend.YOUR.workers.dev

# ── SerpApi (for company news search) ────────────────────────────────
SERPAPI_KEY=your_serpapi_key

# ── Server ───────────────────────────────────────────────────────────
PORT=8000
