# ═══════════════════════════════════════════════════════════════════════════════
#  LeadForge — Frontend Environment Variables
#  Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Cloudflare Worker (SaaS backend — auth, leads, payments, email/WA) ───────
# This is your deployed Cloudflare Worker URL.
# Get it from: Cloudflare Dashboard → Workers → lead-engine-backend → Overview
VITE_API_BASE_URL=https://lead-engine-backend.YOUR_SUBDOMAIN.workers.dev

# ── Autonomous AI Agent Server (FastAPI) ──────────────────────────────────────
# URL of your deployed LeadForge Autonomous FastAPI server.
# Deploy LeadForge-Autonomous-FIXED to Railway, Fly.io, or any Python host.
VITE_AGENT_API_URL=https://your-agent-server.up.railway.app

# ── Agent Server Security Key ─────────────────────────────────────────────────
# Shared secret that guards FastAPI routes from public access.
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Set the SAME value as AGENT_API_KEY in your Railway environment variables.
VITE_AGENT_API_KEY=your_generated_secret_key_here

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Get from: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Add your frontend URL and https://your-frontend.com/auth/callback to Authorized redirect URIs
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
