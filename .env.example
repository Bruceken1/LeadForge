# ── Groq (replaces Vultr Serverless Inference) ───────────────────────────────
# Free tier, no credit card: https://console.groq.com → API Keys → Create key
GROQ_API_KEY=gsk_your_groq_key_here
GROQ_FAST_MODEL=llama-3.1-8b-instant
GROQ_SMART_MODEL=llama-3.3-70b-versatile

# ── Database — Railway Postgres ───────────────────────────────────────────────
# Railway auto-injects $DATABASE_URL when you add a Postgres service.
# For local dev, use a local Postgres or Neon.tech free DB.
DATABASE_URL=postgresql://user:password@host:5432/railway

# ── LeadEngine Cloudflare Worker ─────────────────────────────────────────────
LEADENGINE_API_URL=https://lead-engine-backend.YOUR_SUBDOMAIN.workers.dev

# ── SerpApi (optional — company news search) ─────────────────────────────────
# Free 100 searches/month: https://serpapi.com
SERPAPI_KEY=your_serpapi_key

# ── Server ───────────────────────────────────────────────────────────────────
# Railway injects PORT automatically — this is only for local dev
PORT=8000

# ── Outreach sender identity ──────────────────────────────────────────────────
# Must match a verified sender/domain in your Resend account
SENDER_EMAIL=outreach@yourdomain.com
SENDER_NAME=Your Company Name
