# ═══════════════════════════════════════════════════════════════════════════════
#  LeadForge Autonomous AI SDR — Backend (FastAPI) Environment Variables
#  Set these in your Railway / Fly.io environment variables dashboard.
# ═══════════════════════════════════════════════════════════════════════════════

# ── AI Models (Groq) ──────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_key_here
GROQ_FAST_MODEL=llama-3.1-8b-instant
GROQ_SMART_MODEL=llama-3.3-70b-versatile

# ── Database (Railway Postgres — auto-injected when using Railway) ────────────
DATABASE_URL=postgresql://user:password@host:5432/railway

# ── LeadEngine (Cloudflare Worker URL — same as VITE_API_BASE_URL) ───────────
# The agent server calls the Worker to scrape leads, send email/WhatsApp.
# This is the same URL as your VITE_API_BASE_URL in the frontend .env
LEADENGINE_API_URL=https://lead-engine-backend.YOUR_SUBDOMAIN.workers.dev
LEADENGINE_TOKEN=  # leave blank — the user's JWT is passed per-run from the frontend

# ── Agent Server Security ─────────────────────────────────────────────────────
# A shared secret that protects all FastAPI routes from public access.
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Set the SAME value as VITE_AGENT_API_KEY in your frontend .env
AGENT_API_KEY=your_generated_secret_key_here

# ── CORS — Allowed Frontend Origins ──────────────────────────────────────────
# Comma-separated list of your frontend domains. The server will reject
# cross-origin requests from any origin not in this list.
ALLOWED_ORIGINS=https://app.leadengine.dime-solutions.co.ke,https://leadengine.dime-solutions.co.ke

# ── Email Sending (Resend) ────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
SENDER_EMAIL=outreach@yourdomain.com
SENDER_NAME=Your Company Name

# ── Autonomous Operation ──────────────────────────────────────────────────────
AUTONOMOUS_MODE=true
ACTIVE_CRM=internal

# ── Optional Integrations ─────────────────────────────────────────────────────
# SerpApi (Google News for buy signals) — 100 free/month: https://serpapi.com
SERPAPI_KEY=your_serpapi_key

# CRM integrations (set ACTIVE_CRM= hubspot | salesforce | pipedrive)
HUBSPOT_ACCESS_TOKEN=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_INSTANCE_URL=
PIPEDRIVE_API_TOKEN=

# Calendar (for meeting booking agent)
GOOGLE_CALENDAR_CREDENTIALS=
GOOGLE_CALENDAR_ID=primary
CALENDLY_API_KEY=
CALENDLY_EVENT_URL=

# Compliance
DATA_RETENTION_DAYS=365
DPC_REGISTRATION_NUMBER=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
